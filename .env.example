# ==========================================================================
# Backend environment variables.
# Local dev: copy to `.env` and fill in. Production (Vercel): set these in
# Project Settings → Environment Variables (do NOT commit real secrets).
# ==========================================================================

# Frontend origin allowed for CORS. In production set this to the deployed
# frontend URL, e.g. https://rivercash-loans-frontend.vercel.app
FRONTEND_URL=http://localhost:3000

# --- Database ---------------------------------------------------------------
# PRODUCTION: set a single DATABASE_URL and the app uses it (SSL auto-enabled
# for non-local hosts). This is the connection string from your Postgres
# provider (Supabase, Neon, RDS, …). Example:
#   DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# LOCAL DEV: used only when DATABASE_URL is NOT set.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rivercash_loans
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_LOGGING=false

# --- Auth -------------------------------------------------------------------
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@rivercashloans.com
ADMIN_PASSWORD=change-me-admin

# --- PII encryption (AES-256-GCM). 64 hex chars = 32 bytes ------------------
ENCRYPTION_KEY=

# --- Integrations (leave blank to run in safe no-op/log mode) ---------------
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=support@rivercashloans.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

USER_MAIL=
USER_PASSWORD=

META_PIXEL_ID=
META_ACCESS_TOKEN=

# --- Supabase storage (CV / generated-document uploads) ---------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CV_BUCKET=northstar-lending
